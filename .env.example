# Environment Configuration
# Copy this file to .env and fill in your credentials

# Server
NODE_ENV=development
PORT=3000

# CVParse API (optional - system works without it)
# Get your free API key from: https://www.cvparse.com/
AI_PROVIDER=cvparse
CVPARSE_API_KEY=your_cvparse_key_here

# Logging
LOG_LEVEL=info

# Notes:
# - .env file is NOT committed to git (see .gitignore)
# - System automatically uses regex extraction if CVParse key is missing
# - Max file upload: 25MB
# - CVParse polling timeout: 300 seconds (5 minutes)

ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
